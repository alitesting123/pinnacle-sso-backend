# Database Configuration
# ======================
# Choose ONE of the following database options:

# Option 1: SQLite (Simple, for local development)
# Uncomment the line below to use SQLite
# DATABASE_URL=sqlite:///./proposal_portal.db

# Option 2: PostgreSQL (Production or advanced local development)
# Format: postgresql://username:password@host:port/database
# Example: DATABASE_URL=postgresql://user:password@localhost:5432/proposal_portal
# For Neon.tech: DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://username:password@localhost:5432/proposal_portal

# Redis Configuration
# ===================
REDIS_URL=redis://localhost:6379/0

# Security
# ========
SECRET_KEY=change-this-to-a-random-secret-key-in-production
ENVIRONMENT=development
DEBUG=True

# AWS Cognito Configuration
# ==========================
AWS_REGION=us-east-1
COGNITO_USER_POOL_ID=your-user-pool-id
COGNITO_CLIENT_ID=your-client-id
COGNITO_CLIENT_SECRET=your-client-secret

# Frontend Configuration
# ======================
FRONTEND_BASE_URL=https://main.dnfe4l5bsjojn.amplifyapp.com

# CORS Origins (comma-separated)
# ===============================
ALLOWED_ORIGINS=https://main.dnfe4l5bsjojn.amplifyapp.com,https://*.dnfe4l5bsjojn.amplifyapp.com,http://localhost:3000,http://localhost:8080,http://localhost:5173
ALLOWED_HOSTS=localhost,127.0.0.1,production-env.eba-qeuwm4sn.us-west-2.elasticbeanstalk.com

# Rate Limiting
# =============
RATE_LIMIT_ENABLED=True

# Logging
# =======
LOG_LEVEL=INFO

# Email Configuration (for proposal notifications)
# =================================================
# GMAIL_SMTP_USER=your-email@gmail.com
# GMAIL_SMTP_PASSWORD=your-app-specific-password
